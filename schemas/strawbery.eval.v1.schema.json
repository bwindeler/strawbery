{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bwindeler/strawbery/schemas/strawbery.eval.v1.schema.json",
  "title": "strawbery eval script (v1)",
  "description": "An eval script: a named set of samples, each a sequence of chat-message inputs the harness replays against a target chatbot. This schema is the contributor-facing spec; sidepanel.js#normalizeEvalScript enforces the runtime semantics (e.g. each sample must contain at least one user message).",
  "type": "object",
  "additionalProperties": false,
  "required": ["samples"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "strawbery.eval.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable kebab-case identifier, unique within the registry."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": { "type": "object" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/sample" }
    }
  },
  "definitions": {
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "input": { "$ref": "#/definitions/input" },
        "target": { "type": "string" },
        "expected_output": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "input": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "Shorthand for a single user message."
        },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/message" }
        }
      ]
    },
    "message": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["content"],
          "properties": {
            "role": {
              "type": "string",
              "enum": ["system", "user", "assistant", "tool"]
            },
            "content": { "type": "string" },
            "name": { "type": "string" },
            "metadata": { "type": "object" }
          }
        }
      ]
    }
  }
}
